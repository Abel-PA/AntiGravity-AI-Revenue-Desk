# Environment Variables Template
# Copy this file to .env and fill in your actual values

# API Keys
OPENAI_API_KEY=your_openai_key_here

# Retell AI (Voice Core)
RETELL_API_KEY=your_retell_key_here
RETELL_AGENT_ID=your_retell_agent_id_here

# Twilio (Voice Routing)
TWILIO_ACCOUNT_SID=your_twilio_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Your Real Mobile Number (phone rings first 6 seconds before AI picks up)
REAL_MOBILE_NUMBER=+17176780349

# GoHighLevel (CRM, SMS, Lead Management) — Direct API Integration
# API Key: GHL Settings → Integrations → Private Integrations → Create New (Location-level)
GHL_API_KEY=your_ghl_private_integration_token_here
# Location ID: GHL Settings → Business Profile
GHL_LOCATION_ID=your_ghl_location_id_here

# Pipeline automation (optional — leave blank to skip)
# Get IDs from GHL → CRM → Pipelines → click a stage → copy ID from URL
GHL_PIPELINE_ID=
GHL_PIPELINE_STAGE_NEW_LEAD=
GHL_PIPELINE_STAGE_HOT_LEAD=

# Client identity (used in SMS messages and Slack alerts)
CLIENT_NAME=PA Digital Growth

# Monitoring & Alerts
SLACK_WEBHOOK_URL=your_slack_webhook_url_here
